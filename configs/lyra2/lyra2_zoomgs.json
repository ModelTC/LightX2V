{
    "model_cls": "lyra2_zoomgs",

    "lyra_repo": "/data/nvme1/wushuo/lyra_proj/Lyra-2",

    "experiment": "lyra2",
    "checkpoint_dir": "checkpoints/model",

    "num_frames_zoom_in": 81,
    "num_frames_zoom_out": 81,
    "num_sampling_step": 20,
    "fps": 24,
    "resolution": "480,832",

    "zoom_in_trajectory": "horizontal_zoom",
    "zoom_out_trajectory": "horizontal_zoom",
    "zoom_in_direction": "right",
    "zoom_out_direction": "left",
    "zoom_in_strength": 0.5,
    "zoom_out_strength": 1.5,

    "guidance": 5.0,
    "shift": 5.0,

    "lora_paths": [
        "checkpoints/lora/realism_boost.safetensors",
        "checkpoints/lora/detail_enhancer.safetensors"
    ],
    "lora_weights": [0.4, 0.4],

    "use_dmd": false,
    "use_moge_scale": true,

    "da3_model_path_custom": "checkpoints/recon/model.pt",
    "da3_frame_interval": 8,
    "da3_max_history_frames": 10,

    "negative_prompt_pt": "checkpoints/text_encoder/negative_prompt.pt",

    "offload": false,
    "offload_when_prompt": false,
    "context_parallel_size": 1
}
